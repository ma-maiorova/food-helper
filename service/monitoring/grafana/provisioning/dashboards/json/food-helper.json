      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "drawStyle": "line" }, "unit": "short", "noValue": "0" } },
      "targets": [
        { "expr": "sum by (error_code) (rate(product_import_failed_items_total[5m]))", "legendFormat": "{{error_code}}" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus-food-helper" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 47 },
      "id": 25,
      "title": "Импорт: дубли URL в батче (дедупликация)",
      "type": "timeseries",
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "drawStyle": "line" }, "unit": "short", "noValue": "0" } },
      "targets": [
        { "expr": "sum by (delivery_service) (rate(product_import_duplicate_overridden_total[5m]))", "legendFormat": "{{delivery_service}}" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus-food-helper" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 47 },
      "id": 26,
      "title": "Импорт: распределение размеров батча (p50/p75/p90/p95)",
      "type": "timeseries",
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "drawStyle": "line" }, "unit": "short" } },
      "targets": [
        { "expr": "product_import_batch_size{quantile=\"0.5\"}", "legendFormat": "p50" },
        { "expr": "product_import_batch_size{quantile=\"0.75\"}", "legendFormat": "p75" },
        { "expr": "product_import_batch_size{quantile=\"0.9\"}", "legendFormat": "p90" },
        { "expr": "product_import_batch_size{quantile=\"0.95\"}", "legendFormat": "p95" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus-food-helper" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 55 },
      "id": 29,
      "title": "Импорт: размер батча p50 (текущее)",
      "type": "stat",
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 400 }] }
        }
      },
      "targets": [
        { "expr": "product_import_batch_size{quantile=\"0.5\"}", "legendFormat": "p50 items" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus-food-helper" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 55 },
      "id": 30,
      "title": "Импорт: размер батча p90 (текущее)",
      "type": "stat",
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 200 }, { "color": "red", "value": 450 }] }
        }
      },
      "targets": [
        { "expr": "product_import_batch_size{quantile=\"0.9\"}", "legendFormat": "p90 items" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus-food-helper" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 59 },
      "id": 27,
      "title": "Импорт: p50 / p95 латентность батча",
      "type": "timeseries",
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "drawStyle": "line" }, "unit": "ms" } },
      "targets": [
        { "expr": "product_import_duration_seconds{quantile=\"0.5\"} * 1000", "legendFormat": "p50 {{delivery_service}}" },
        { "expr": "product_import_duration_seconds{quantile=\"0.95\"} * 1000", "legendFormat": "p95 {{delivery_service}}" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus-food-helper" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 59 },
      "id": 28,
      "title": "Импорт: ошибки по службе и коду (таблица)",
      "type": "table",
      "options": { "sortBy": [{ "displayName": "Value", "desc": true }] },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "sum by (delivery_service, error_code) (increase(product_import_failed_items_total[$__range]))", "legendFormat": "{{delivery_service}} / {{error_code}}", "instant": true }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 68 }, "id": 40, "title": "Использование", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus-food-helper" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 69 },
      "id": 41,
      "title": "Поисков всего (за всё время)",
      "type": "stat",
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0"
        }
      },
      "targets": [
        { "expr": "sum(product_search_requests_total)", "legendFormat": "total" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus-food-helper" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 69 },
      "id": 42,
      "title": "Импортировано товаров (за всё время)",
      "type": "stat",
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0"
        }
      },
      "targets": [
        { "expr": "sum(product_import_created_items_total) + sum(product_import_updated_items_total)", "legendFormat": "imported" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus-food-helper" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 69 },
      "id": 44,
      "title": "Поисков с бота (total)",
      "type": "stat",
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0"
        }
      },
      "targets": [
        { "expr": "sum(product_search_requests_total{source=\"bot\"})", "legendFormat": "bot" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus-food-helper" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 69 },
      "id": 45,
      "title": "Поисков с web (total)",
      "type": "stat",
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0"
        }
      },
      "targets": [
        { "expr": "sum(product_search_requests_total{source=\"web\"})", "legendFormat": "web" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus-food-helper" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 73 },
      "id": 43,
      "title": "Поиски: bot vs web (rate/min)",
      "type": "timeseries",
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 15, "drawStyle": "line" }, "unit": "reqps" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "bot" }, "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "web" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        { "expr": "sum by (source) (rate(product_search_requests_total[1m]))", "legendFormat": "{{source}}" }
      ]
    }

  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["food-helper"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Food Helper API",
  "uid": "food-helper-v2",
  "version": 4
