# =============================================================
# Postgres (обязательные)
# =============================================================
POSTGRES_DB=food_helper
POSTGRES_USER=food_user
POSTGRES_PASSWORD=CHANGE_ME

# =============================================================
# API (обязательные)
# =============================================================
# Ключ для /api/v1/admin/* — используется и парсером
ADMIN_API_KEY=CHANGE_ME_STRONG_KEY

# JDBC URL — обычно менять не нужно (postgres — имя контейнера в docker-сети)
JDBC_URL=jdbc:postgresql://postgres:5432/food_helper

# =============================================================
# Telegram Bot (обязательные)
# =============================================================
# Токен бота из @BotFather
BOT_TOKEN=CHANGE_ME

# URL API бэкенда изнутри docker-сети
# prod/local: http://nginx:80 (через nginx-прокси)
# отладка без nginx: http://api:8080
API_BASE_URL=http://nginx:80

# =============================================================
# Порты и bind-хосты (разные для local и prod)
# =============================================================

# Nginx
NGINX_BIND_HOST=0.0.0.0   # prod: 0.0.0.0 (публичный), local: 0.0.0.0
NGINX_PORT=80              # prod: 80, local: 8090

# Postgres
POSTGRES_BIND_HOST=0.0.0.0  # prod: 127.0.0.1 (только SSH-туннель), local: 0.0.0.0
POSTGRES_PORT=5432           # prod: 5432, local: 5433

# API
API_BIND_HOST=0.0.0.0  # prod: 127.0.0.1 (только SSH-туннель), local: 0.0.0.0

# =============================================================
# Monitoring
# =============================================================
GRAFANA_PASSWORD=CHANGE_ME
# GRAFANA_USER=admin

# Prometheus
PROMETHEUS_BIND_HOST=127.0.0.1  # prod: 127.0.0.1, local: 0.0.0.0
PROMETHEUS_PORT=9090             # prod: 9090, local: 9091

# Grafana
GRAFANA_BIND_HOST=127.0.0.1  # prod: 127.0.0.1, local: 0.0.0.0
GRAFANA_PORT=3000             # prod: 3000, local: 3001

# =============================================================
# Parser Scheduler (parser-scheduler сервис)
# =============================================================

# URL импорт-эндпоинта. Изнутри docker-сети — обращается к api:8080 напрямую.
FOOD_HELPER_API_URL=http://api:8080/api/v1/admin/import

# Ключ авторизации — ДОЛЖЕН совпадать с ADMIN_API_KEY выше
FOOD_HELPER_API_KEY=CHANGE_ME_STRONG_KEY

# Сайты для парсинга (через пробел)
PARSER_SITES=vkusvill lavka

# Кол-во продуктов на сайт за один суточный прогон
PARSER_PRODUCT_COUNT=1000

# Кол-во страниц для сбора ссылок (55 страниц ≈ 1100 товаров у ВкусВилла)
PARSER_LINK_PAGES=55

# Размер батча при выгрузке в API (максимум 500)
PARSER_BATCH_SIZE=200

